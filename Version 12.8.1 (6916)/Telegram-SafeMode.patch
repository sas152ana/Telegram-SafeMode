+    private TLRPC.Message sanitizeDialogLastMessage(TLRPC.Dialog dialog, TLRPC.Message message) {
+        if (org.telegram.messenger.SecretModeController.getInstance(currentAccount).isSecretModeActive) {
+            return message; // В секретном режиме отдаем сообщение как есть
+        }
+        if (message == null) {
+            return null;
+        }
+        MessageObject tempObj = new MessageObject(currentAccount, message, false, false);
+        if (!org.telegram.messenger.SecretModeController.getInstance(currentAccount).isMessageHidden(tempObj)) {
+            return message; // Сообщение безопасно, оставляем
+        }
+        TLRPC.Message safeMessage = null;
+        SQLiteCursor safeCursor = null;
+        try {
+            safeCursor = database.queryFinalized("SELECT data, mid, send_state, read_state FROM messages_v2 WHERE uid = " + dialog.id + " AND mid < " + message.id + " ORDER BY mid DESC LIMIT 100");
+            while (safeCursor.next()) {
+                NativeByteBuffer safeData = safeCursor.byteBufferValue(0);
+                if (safeData != null) {
+                    TLRPC.Message safeMsg = TLRPC.Message.TLdeserialize(safeData, safeData.readInt32(false), false);
+                    if (safeMsg != null) {
+                        safeMsg.readAttachPath(safeData, getUserConfig().clientUserId);
+                        safeData.reuse();
+                        safeMsg.id = safeCursor.intValue(1);
+                        safeMsg.send_state = safeCursor.intValue(2);
+                        MessageObject.setUnreadFlags(safeMsg, safeCursor.intValue(3));
+                        safeMsg.dialog_id = dialog.id;
+
+                        MessageObject safeObj = new MessageObject(currentAccount, safeMsg, false, false);
+                        if (!org.telegram.messenger.SecretModeController.getInstance(currentAccount).isMessageHidden(safeObj)) {
+                            safeMessage = safeMsg;
+                            dialog.top_message = safeMessage.id;
+                            dialog.last_message_date = safeMessage.date;
+                            break;
+                        }
+                    } else {
+                        safeData.reuse();
+                    }
+                }
+            }
+            if (safeMessage == null) {
+                dialog.top_message = 0;
+                dialog.last_message_date = 0;
+            }
+        } catch (Exception e) {
+            FileLog.e(e);
+        } finally {
+            if (safeCursor != null) {
+                safeCursor.dispose();
+            }
+        }
+        return safeMessage;
+    }
