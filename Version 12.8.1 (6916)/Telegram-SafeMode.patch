--- Telegram-Orig/TMessagesProj/src/main/java/org/telegram/messenger/SecretModeController.java	1970-01-01 03:00:00.000000000 +0300
+++ Telegram-SafeMode/TMessagesProj/src/main/java/org/telegram/messenger/SecretModeController.java	2026-07-05 10:25:02.659378600 +0300
@@ -0,0 +1,590 @@
+package org.telegram.messenger;
+
+import android.content.Context;
+import android.content.SharedPreferences;
+
+import org.telegram.ui.ActionBar.BaseFragment;
+
+import java.nio.charset.StandardCharsets;
+import java.util.List;
+
+public class SecretModeController {
+    // Массив контроллеров (по одному на каждый аккаунт)
+    private static final SecretModeController[] Instance = new SecretModeController[UserConfig.MAX_ACCOUNT_COUNT];
+    // Номер аккаунта, к которому привязан этот контроллер
+    private final int currentAccount;
+    // Переменная, которая знает, открыты ли сейчас скрытые чаты (у каждого аккаунта своя)
+    public volatile boolean isSecretModeActive = false;
+    private final SharedPreferences prefs;
+    public int failedAttempts = 0;
+    public long lockTime = 0;
+
+    // Singleton с учетом мультиаккаунта
+    public static SecretModeController getInstance(int num) {
+        SecretModeController localInstance = Instance[num];
+        if (localInstance == null) {
+            synchronized (SecretModeController.class) {
+                localInstance = Instance[num];
+                if (localInstance == null) {
+                    Instance[num] = localInstance = new SecretModeController(num, num);
+                }
+            }
+        }
+        return localInstance;
+    }
+
+    private SecretModeController(int currentAccount, int instance) {
+        this.currentAccount = currentAccount;
+        // Номер аккаунта, к которому привязан этот контроллер
+        // Создаем УНИКАЛЬНЫЙ файл настроек для каждого аккаунта
+        prefs = ApplicationLoader.applicationContext.getSharedPreferences("secret_mode_prefs_" + instance, Context.MODE_PRIVATE);
+    }
+
+    // --- НАШ КОД: Умная проверка для сообщений (включая пересылки в Избранное) ---
+    public boolean isMessageHidden(org.telegram.messenger.MessageObject msg) {
+        if (msg == null) return false;
+        long did = msg.getDialogId();
+
+        // Сначала проверяем, не скрыт ли сам чат, где лежит сообщение
+        if (isDialogHidden(did)) return true;
+
+        // --- НАШ КОД: Надежная проверка для "Избранного 2.0" ---
+        if (msg.messageOwner != null && msg.messageOwner.saved_peer_id != null) {
+            long savedPeerId = org.telegram.messenger.MessageObject.getPeerId(msg.messageOwner.saved_peer_id);
+            if (savedPeerId != 0 && isDialogHidden(savedPeerId)) {
+                return true;
+            }
+        }
+        // --- КОНЕЦ НАШЕГО КОДА ---
+
+        // Если это "Избранное" (Saved Messages), проверяем, откуда переслано сообщение
+        long selfId = org.telegram.messenger.UserConfig.getInstance(currentAccount).clientUserId;
+        if (did == selfId && msg.messageOwner != null && msg.messageOwner.fwd_from != null) {
+
+            // 1. Проверяем первоначального автора (от кого переслано)
+            if (msg.messageOwner.fwd_from.from_id != null) {
+                long fromId = org.telegram.messenger.MessageObject.getPeerId(msg.messageOwner.fwd_from.from_id);
+                if (fromId != 0 && isDialogHidden(fromId)) {
+                    return true;
+                }
+            }
+
+            // 2. Проверяем чат/канал, из которого сообщение было сохранено
+            if (msg.messageOwner.fwd_from.saved_from_peer != null) {
+                long savedFromPeerId = org.telegram.messenger.MessageObject.getPeerId(msg.messageOwner.fwd_from.saved_from_peer);
+                if (savedFromPeerId != 0 && isDialogHidden(savedFromPeerId)) {
+                    return true;
+                }
+            }
+        }
+        return false;
+    }
+
+    // --- КОНЕЦ НАШЕГО КОДА ---
+    // --- БЛОК ЧАТОВ ---
+    private volatile java.util.Set<Long> cachedHiddenDialogs = null;
+
+    public boolean isDialogHidden(long dialogId) {
+        if (cachedHiddenDialogs == null) {
+            synchronized (this) {
+                if (cachedHiddenDialogs == null) {
+                    java.util.Set<Long> tempSet = new java.util.HashSet<>();
+                    java.util.Map<String, ?> allEntries = prefs.getAll();
+                    for (java.util.Map.Entry<String, ?> entry : allEntries.entrySet()) {
+                        if (entry.getKey().startsWith("hidden_dialog_") && Boolean.TRUE.equals(entry.getValue())) {
+                            try {
+                                tempSet.add(Long.parseLong(entry.getKey().replace("hidden_dialog_", "")));
+                            } catch (Exception ignore) {}
+                        }
+                    }
+                    cachedHiddenDialogs = java.util.Collections.synchronizedSet(tempSet);
+                }
+            }
+        }
+        return cachedHiddenDialogs.contains(dialogId);
+    }
+
+    public void setDialogHidden(long dialogId, boolean hide) {
+        // Синхронно обновляем и кэш, и базу данных
+        if (cachedHiddenDialogs != null) {
+            if (hide) {
+                cachedHiddenDialogs.add(dialogId);
+            } else {
+                cachedHiddenDialogs.remove(dialogId);
+            }
+        }
+        prefs.edit().putBoolean("hidden_dialog_" + dialogId, hide).apply();
+    }
+
+    // --- БЛОК ПАПОК ---
+    private volatile java.util.Set<Integer> cachedHiddenFolders = null;
+
+    public boolean isFolderHidden(int filterId) {
+        if (cachedHiddenFolders == null) {
+            synchronized (this) {
+                if (cachedHiddenFolders == null) {
+                    java.util.Set<Integer> tempSet = new java.util.HashSet<>();
+                    java.util.Map<String, ?> allEntries = prefs.getAll();
+                    for (java.util.Map.Entry<String, ?> entry : allEntries.entrySet()) {
+                        if (entry.getKey().startsWith("hidden_folder_") && Boolean.TRUE.equals(entry.getValue())) {
+                            try {
+                                tempSet.add(Integer.parseInt(entry.getKey().replace("hidden_folder_", "")));
+                            } catch (Exception ignore) {}
+                        }
+                    }
+                    cachedHiddenFolders = java.util.Collections.synchronizedSet(tempSet);
+                }
+            }
+        }
+        return cachedHiddenFolders.contains(filterId);
+    }
+
+    public void setFolderHidden(int filterId, boolean hide) {
+        // Синхронно обновляем и кэш, и базу данных
+        if (cachedHiddenFolders != null) {
+            if (hide) {
+                cachedHiddenFolders.add(filterId);
+            } else {
+                cachedHiddenFolders.remove(filterId);
+            }
+        }
+        prefs.edit().putBoolean("hidden_folder_" + filterId, hide).apply();
+    }
+
+    // --- БЛОК ПАРОЛЯ ---
+    public boolean hasPassword() {
+        return prefs.contains("secret_password");
+    }
+
+    // Вспомогательный метод для хэширования пароля (SHA-256)
+    // Получаем существующую соль или генерируем новую (уникальна для каждого аккаунта)
+    private byte[] getOrGenerateSalt() {
+        String saltBase64 = prefs.getString("secret_salt", null);
+        if (saltBase64 == null) {
+            byte[] salt = new byte[16];
+            new java.security.SecureRandom().nextBytes(salt);
+            // Сохраняем соль в Base64
+            saltBase64 = android.util.Base64.encodeToString(salt, android.util.Base64.NO_WRAP);
+            prefs.edit().putString("secret_salt", saltBase64).apply();
+            return salt;
+        }
+        return android.util.Base64.decode(saltBase64, android.util.Base64.NO_WRAP);
+    }
+
+    // Вспомогательный метод для хэширования пароля (PBKDF2)
+    private String hashPassword(String password) {
+                try {
+                        byte[] salt = getOrGenerateSalt();
+
+                                // PBKDF2WithHmacSHA1 поддерживается на всех версиях Android
+                                        // 65536 итераций - стандарт для надежного замедления перебора
+                                                javax.crypto.SecretKeyFactory factory = javax.crypto.SecretKeyFactory.getInstance("PBKDF2WithHmacSHA1");
+                        java.security.spec.KeySpec spec = new javax.crypto.spec.PBEKeySpec(password.toCharArray(), salt, 65536, 256);
+                        byte[] hash = factory.generateSecret(spec).getEncoded();
+                        return android.util.Base64.encodeToString(hash, android.util.Base64.NO_WRAP);
+                    } catch (Exception e) {
+                        org.telegram.messenger.FileLog.e(e);
+                        try {
+                                java.security.MessageDigest md = java.security.MessageDigest.getInstance("SHA-256");
+                                byte[] hash = md.digest(password.getBytes());
+                                return android.util.Base64.encodeToString(hash,android.util.Base64.NO_WRAP);
+                            }catch(Exception ex){
+                                throw new RuntimeException(ex);
+
+                                    }
+                    }
+            }
+
+    // Флаг: при следующем processLoadedUnreadMessages нужно показать уведомления «громко»
+    public final java.util.Set<Long> dialogsToNotifyLoud =
+            java.util.Collections.synchronizedSet(new java.util.HashSet<>());
+
+    public boolean checkPassword(String input) {
+        String savedPassword = prefs.getString("secret_password", null);
+        if (savedPassword == null) return false;
+
+        // Проверяем, не заблокирован ли ввод (защита от брутфорса)
+        long lock = prefs.getLong("lock_time", 0);
+        if (System.currentTimeMillis() < lock) return false;
+
+        // ОБРАТНАЯ СОВМЕСТИМОСТЬ:
+        if (input.equals(savedPassword)) {
+            setPassword(input);
+            prefs.edit().putInt("failed_attempts", 0).apply();
+            return true;
+        }
+
+        String inputHash = hashPassword(input);
+
+        // MessageDigest.isEqual защищает от атак по времени (Timing attacks)
+        boolean matched = java.security.MessageDigest.isEqual(inputHash.getBytes(), savedPassword.getBytes());
+
+        if (matched) {
+            prefs.edit().putInt("failed_attempts", 0).apply();
+            return true;
+        } else {
+            int attempts = prefs.getInt("failed_attempts", 0) + 1;
+            prefs.edit().putInt("failed_attempts", attempts).apply();
+            if (attempts >= 5) {
+                // Блокируем на 60 секунд после 5 неудачных попыток
+                prefs.edit().putLong("lock_time", System.currentTimeMillis() + 60000).apply();
+            }
+            return false;
+        }
+    }
+
+    public void setPassword(String newPassword) {
+        // Прогоняем пароль через алгоритм и записываем в файл настроек нечитаемую строку
+        String hashed = hashPassword(newPassword);
+        prefs.edit().putString("secret_password", hashed).apply();
+    }
+
+    // --- НАШ КОД ДЛЯ ТАЙМЕРА ---
+    public volatile long lastBackgroundTime = 0;
+
+    // Читаем настройку (по умолчанию 1.0 минута)
+    public float getTimeout() {
+        return prefs.getFloat("secret_timeout", 1.0f);
+    }
+
+    // Сохраняем настройку
+    public void setTimeout(float minutes) {
+        prefs.edit().putFloat("secret_timeout", minutes).apply();
+    }
+
+    // Фоновая задача для срабатывания таймера
+    public final Runnable backgroundTimerRunnable = new Runnable() {
+        @Override
+        public void run() {
+            if (isSecretModeActive) {
+                isSecretModeActive = false;
+                applySafeModeState();
+            }
+        }
+    };
+
+    public void lockAppIfNeeded() {
+        if (isSecretModeActive && lastBackgroundTime != 0) {
+            float timeoutMin = getTimeout();
+            if (timeoutMin < 0) {
+                // Если меньше 0, ничего не делаем по времени (только при закрытии приложения)
+            } else if (timeoutMin == 0) {
+                // Блокируем мгновенно
+                isSecretModeActive = false;
+                applySafeModeState();
+            } else {
