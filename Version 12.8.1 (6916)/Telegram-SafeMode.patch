+        org.telegram.messenger.AndroidUtilities.runOnUIThread(() -> {
+            if (org.telegram.ui.LaunchActivity.instance != null && org.telegram.ui.LaunchActivity.instance.getActionBarLayout() != null) {
+                org.telegram.ui.ActionBar.INavigationLayout navLayout = org.telegram.ui.LaunchActivity.instance.getActionBarLayout();
+                if (navLayout instanceof org.telegram.ui.ActionBar.ActionBarLayout) {
+                    java.util.List<org.telegram.ui.ActionBar.BaseFragment> stack = ((org.telegram.ui.ActionBar.ActionBarLayout) navLayout).getFragmentStack();
+                    if (stack != null) {
+                        for (int i = 0; i < stack.size(); i++) {
+                            if (stack.get(i) instanceof org.telegram.ui.DialogsActivity) {
+                                org.telegram.ui.DialogsActivity dialogsActivity = (org.telegram.ui.DialogsActivity) stack.get(i);
+
+                                // Используем рефлексию, чтобы безопасно дотянуться до приватного filterTabsView
+                                try {
+                                    java.lang.reflect.Field field = org.telegram.ui.DialogsActivity.class.getDeclaredField("filterTabsView");
+                                    field.setAccessible(true);
+                                    org.telegram.ui.Components.FilterTabsView tabsView = (org.telegram.ui.Components.FilterTabsView) field.get(dialogsActivity);
+
+                                    if (tabsView != null && !tabsView.isFirstTabSelected()) {
+                                        tabsView.selectFirstTab(); // Плавно перекидываем на "Все чаты"
+                                    }
+                                } catch (Exception e) {
+                                    // Запасной вариант, если вдруг рефлексия не сработала
+                                    dialogsActivity.scrollToFolder(0);
+                                }
+                                break; // Нашли DialogsActivity, дальше идти по стеку не нужно
+                            }
+                        }
+                    }
+                }
+            }
+        });
+    }
