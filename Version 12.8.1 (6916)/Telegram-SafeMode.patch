+    private static long getDialogId(List<BaseFragment> stack, int i) {
+        BaseFragment f = stack.get(i);
+        long dialogId = 0;
+
+        // Универсальный способ вытащить ID чата из любого окна Телеграма (Чат, Профиль, Медиа)
+        try {
+            java.lang.reflect.Field field = f.getClass().getDeclaredField("dialog_id");
+            field.setAccessible(true);
+            dialogId = field.getLong(f);
+        } catch (Throwable e) {
+            try {
+                java.lang.reflect.Method method = f.getClass().getMethod("getDialogId");
+                Object result = method.invoke(f);
+                if (result instanceof Long) {
+                    dialogId = (Long) result;
+                }
+            } catch (Throwable e2) {
+                // Это окно не привязано к чату (например, Настройки)
+            }
+        }
+        return dialogId;
+    }
